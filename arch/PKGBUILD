# Maintainer: razer-tray contributors
#
# Local PKGBUILD for in-tree development builds and the GitHub release
# workflow. Builds straight from the parent directory checkout.
# AUR PKGBUILDs (self-contained, with `source=` URLs) live in arch/aur/.
pkgname=razer-tray
pkgver=0.5.0
pkgrel=1
pkgdesc='Minimal Linux tray indicator for Razer wireless mouse and keyboard battery level'
arch=('x86_64')
url=''
license=('MIT')
depends=('gcc-libs' 'dbus' 'openrazer-driver-dkms')
makedepends=('cargo')
install="$pkgname.install"
source=()

_projectdir="$startdir/.."

prepare() {
    cd "$_projectdir"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$_projectdir"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR="$srcdir/target"
    cargo build --frozen --release
}

package() {
    install -Dm755 "$srcdir/target/release/$pkgname" \
        "$pkgdir/usr/bin/$pkgname"
    install -Dm644 "$startdir/$pkgname.service" \
        "$pkgdir/usr/lib/systemd/user/$pkgname.service"
    install -Dm644 "$startdir/$pkgname.desktop" \
        "$pkgdir/etc/xdg/autostart/$pkgname.desktop"
    install -Dm644 "$_projectdir/LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "$_projectdir/README.md" \
        "$pkgdir/usr/share/doc/$pkgname/README.md"

    install -d "$pkgdir/usr/share/$pkgname/icons"
    install -m644 "$_projectdir/icons/"*.png \
        "$pkgdir/usr/share/$pkgname/icons/"

    install -Dm755 "$startdir/$pkgname-udev-trigger.sh" \
        "$pkgdir/usr/lib/$pkgname/udev-trigger"
    install -Dm644 "$startdir/99-$pkgname.rules" \
        "$pkgdir/usr/lib/udev/rules.d/99-$pkgname.rules"
}
